{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "py .claude/hooks/guard_destructive_git.py",
            "timeout": 10,
            "statusMessage": "Checking for destructive git operations..."
          },
          {
            "type": "command",
            "command": "py .claude/hooks/warn_verif_before_commit.py",
            "timeout": 10,
            "statusMessage": "Verif reelle avant commit (dispositif)..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py .claude/supervision/scan_transcripts.py",
            "timeout": 60,
            "statusMessage": "Supervision agents : scan incremental des transcripts..."
          },
          {
            "type": "command",
            "command": "py .claude/hooks/remind_veille_agentic.py",
            "timeout": 10,
            "statusMessage": "Cadence veille agentic..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py .claude/hooks/orchestrator_gate.py",
            "timeout": 10,
            "statusMessage": "Grille de qualification orchestrateur..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "py .claude/supervision/log_usage.py",
            "timeout": 10,
            "statusMessage": "Journal usage agents..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./secrets/**)",
      "Read(./config/credentials.json)",
      "Read(C:/Users/claude.camus/Documents/VSCode*/.env)",
      "Read(C:/Users/claude.camus/Documents/VSCode*/secrets/**)",
      "Read(C:/Users/claude.camus/Documents/VSCode*/config/credentials.json)"
    ]
  }
}